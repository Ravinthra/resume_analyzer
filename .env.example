# =============================================================
# AI Resume Analyzer — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================

# Django Secret Key (generate one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
DJANGO_SECRET_KEY=your-secret-key-here

# Debug mode (set to False in production)
DJANGO_DEBUG=False

# Allowed hosts (comma-separated)
DJANGO_ALLOWED_HOSTS=your-app.onrender.com,localhost,127.0.0.1

# Hugging Face token (optional — for private model downloads)
HF_TOKEN=

# Python settings for production
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1
